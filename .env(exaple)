# =====================================================================
# --- REMOTE PC CONFIGURATION ---
# =====================================================================
# Format: JSON object where each key is a PC name (used by the agent).
# Required fields per PC:
#   "ip"  — Local IP address of the PC
#   "mac" — MAC address for Wake-on-LAN (format: AA:BB:CC:DD:EE:FF)
#
# Optional fields per PC:
#   "ssh_pass" — SSH password for THIS specific PC.
#                If not set, SSH_PASS_DEFAULT is used as fallback.
#
# Add as many PCs as you want — the agent will know all of them automatically.
#
# Example with 2 PCs (one uses default password, one has its own):
# REMOTE_PCS='{"main_pc": {"ip": "192.168.178.140", "mac": "AA:BB:CC:DD:EE:FF"}, "comfy_server": {"ip": "192.168.178.50", "mac": "11:22:33:44:55:66", "ssh_pass": "myOtherPassword"}}'
#
REMOTE_PCS='{"main_pc": {"ip": "192.168.178.140", "mac": "AA:BB:CC:DD:EE:FF"}, "comfy_server": {"ip": "192.168.178.50", "mac": "11:22:33:44:55:66"}}'


# =====================================================================
# --- SSH CREDENTIALS ---
# =====================================================================

# SSH_USER: The Linux username used for all SSH connections.
# Default: root
SSH_USER=root

# SSH_PASS_DEFAULT: The default SSH password used for ALL PCs
# unless a PC has its own "ssh_pass" set in REMOTE_PCS above.
#
# To use SSH key auth instead (more secure):
#   1. Leave SSH_PASS_DEFAULT empty
#   2. Mount your SSH keys into the container in docker-compose.yml:
#      volumes:
#        - ~/.ssh:/root/.ssh:ro
#
SSH_PASS_DEFAULT=yourPasswordHere


# =====================================================================
# --- REDIS ---
# =====================================================================
# Used for LLM response caching (speeds up repeated questions).
# Default points to the Redis container in docker-compose.yml.
# Only change if you use an external Redis instance.
REDIS_URL=redis://redis:6379


# =====================================================================
# --- LANGGRAPH CLI CHECKPOINTER ---
# =====================================================================
# Phase 1 uses LangGraph's native Mongo checkpointer via langgraph.json.
# For real Mongo checkpointing, LangGraph requires a replica-set capable URI
# with the database name in the path. A standalone mongo:7.0 container is not
# enough unless it is configured as a replica set.
#
# Example:
# LS_MONGODB_URI=mongodb://mongodb:27017/langgraph?replicaSet=rs0
LS_MONGODB_URI=mongodb://mongodb:27017/langgraph?replicaSet=rs0

# =====================================================================
# --- OPENAI BRIDGE <-> LANGGRAPH ---
# =====================================================================
# URL of the native LangGraph API ("brain") that the FastAPI bridge calls.
LANGGRAPH_API_URL=http://langgraph-api:2024

# Graph/assistant id exposed by langgraph.json. Keep this in sync with the
# graph id `alpha_ravis`.
LANGGRAPH_ASSISTANT_ID=alpha_ravis

# Model name shown to LibreChat through /v1/models. This is a bridge-facing
# display id, not the real LiteLLM model id.
OPENAI_MODEL_NAME=my-agent

# Max seconds the bridge waits for one LangGraph run before returning a clean
# timeout message to LibreChat.
BRIDGE_RUN_TIMEOUT_SECONDS=180

# Streaming mode for LibreChat.
# Allowed values:
#   events = stream LangGraph message events as OpenAI SSE chunks
#   final or messages = wait for final content and stream it as one OpenAI SSE reply
BRIDGE_STREAM_MODE=events

# How the bridge syncs LibreChat messages into LangGraph:
# Allowed values:
#   delta = after the first thread sync, send only new user messages
#   full  = send the whole LibreChat message array every request
# Delta keeps LangGraph compression useful because LibreChat's full UI history
# does not get re-injected on every turn.
BRIDGE_MESSAGE_SYNC_MODE=delta

# If true, the bridge emits short visible "Status:" chunks during streaming
# runs. This is OpenAI-SSE compatible content, so LibreChat should display it
# like normal assistant text. Keep false if you want quiet responses.
BRIDGE_SHOW_ACTIVITY_EVENTS=false

# Activity detail level when BRIDGE_SHOW_ACTIVITY_EVENTS=true.
# Allowed values:
#   summary = show short LangGraph step summaries
#   debug   = also show raw non-message event names
#   off     = suppress activity chunks even if the boolean is true
BRIDGE_ACTIVITY_DETAIL=summary

# =====================================================================
# --- MEMORY + CONTEXT COMPRESSION ---
# =====================================================================
# Approximate active message-window token limit. If the current LangGraph
# thread goes above this, older messages are summarized and archived.
ALPHARAVIS_ACTIVE_TOKEN_LIMIT=10000

# Number of most recent messages kept verbatim in the active thread after
# chat compression. Older messages become an archive summary plus raw archive.
ALPHARAVIS_CONTEXT_KEEP_LAST_MESSAGES=12

# Enables the second compression tier for old archive blocks. This keeps long
# running chats searchable without deleting raw archive records.
ALPHARAVIS_ENABLE_HIERARCHICAL_COMPRESSION=true

# Approximate token budget for uncompressed archive records within one chat
# thread. Above this, older archive records are summarized into a collection.
ALPHARAVIS_ARCHIVE_TOKEN_LIMIT=50000

# Number of newest archive records kept as separate records when creating an
# archive collection. These remain easy to inspect individually.
ALPHARAVIS_ARCHIVE_KEEP_RECENT_RECORDS=8

# Allows the user to pause compression for one run by saying things like
# "keine Kompression", "nicht komprimieren", or "skip compression".
ALPHARAVIS_ALLOW_USER_COMPRESSION_PAUSE=true

# If true, AlphaRavis adds a visible Memory-Notice to LibreChat whenever
# compression happens or when compression was explicitly paused.
ALPHARAVIS_SHOW_MEMORY_NOTICES=true

# Max archive-search hits returned to the context retriever inside the current
# chat thread. This keeps retrieved memory bounded instead of dumping history.
ALPHARAVIS_ARCHIVE_SEARCH_LIMIT=5

# Max archive-search hits when the user explicitly asks to search other chats
# / all archives through include_other_threads=true.
ALPHARAVIS_CROSS_THREAD_ARCHIVE_SEARCH_LIMIT=3

# Editable on-demand self-description. Agents do not inject this into every
# chat; they read it only via read_alpha_ravis_architecture when the user asks
# about AlphaRavis architecture, capabilities, memory, bridge, or safety.
ALPHARAVIS_ARCHITECTURE_DOC_PATH=/workspace/docs/ALPHARAVIS_ARCHITECTURE.md

# Max characters the architecture-doc tool may return in one call. This keeps
# "what can you do?" answers useful without dumping the whole document.
ALPHARAVIS_ARCHITECTURE_DOC_MAX_CHARS=6000

# =====================================================================
# --- SAFE WORKFLOW SKILL LIBRARY ---
# =====================================================================
# Enables retrieval/storage of reusable workflow skills in MongoDBStore.
# Active skills are non-binding hints only; they do not execute tools directly.
ALPHARAVIS_ENABLE_SKILL_LIBRARY=true

# Max number of approved active skills to retrieve for the current user task.
ALPHARAVIS_SKILL_LIBRARY_SEARCH_LIMIT=3

# Max characters from retrieved active skills injected into the graph prompt.
ALPHARAVIS_SKILL_CONTEXT_MAX_CHARS=2500

# Safety switch for turning an inactive skill candidate into an active skill.
# Keep false by default. Temporarily set true only when intentionally reviewing
# and promoting a specific skill candidate.
ALPHARAVIS_ALLOW_SKILL_PROMOTION=false


# =====================================================================
# --- SEARCH (TAVILY) ---
