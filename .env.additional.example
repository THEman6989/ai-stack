# =====================================================================
# AlphaRavis Supplemental Environment Example
# =====================================================================
#
# Supplements .env(exaple). Merge these blocks into the main example later.
# Defaults are conservative. Enable debug/experimental features intentionally.


# =====================================================================
# OPTIONAL LOGGING / DEBUGGING
# =====================================================================

ALPHARAVIS_OPERATIONAL_LOGGING=true
ALPHARAVIS_DEBUG_ALL_LOGGING=false
ALPHARAVIS_LOG_CONSOLE=true
ALPHARAVIS_LOG_JSONL=true
ALPHARAVIS_LOG_DIR=/logs
ALPHARAVIS_LOG_RETENTION_DAYS=4
ALPHARAVIS_LOG_LEVEL=INFO
ALPHARAVIS_DEBUG_LOG_LEVEL=DEBUG
ALPHARAVIS_LOG_MAX_FIELD_CHARS=4000
ALPHARAVIS_DEBUG_LOG_MAX_FIELD_CHARS=12000

# Full debug override while investigating:
# ALPHARAVIS_DEBUG_ALL_LOGGING=true
# ALPHARAVIS_LOG_LEVEL=DEBUG
# ALPHARAVIS_DEBUG_LOG_LEVEL=DEBUG
# ALPHARAVIS_DEBUG_LOG_MAX_FIELD_CHARS=50000


# =====================================================================
# OPTIONAL CORE LLM RUNTIME
# =====================================================================

ALPHARAVIS_LLM_TIMEOUT_SECONDS=120
ALPHARAVIS_LLM_MAX_RETRIES=0
ALPHARAVIS_LLM_STREAMING=true
ALPHARAVIS_ENABLE_THINKING=true
ALPHARAVIS_PRESERVE_THINKING=true


# =====================================================================
# OPTIONAL MCP / TOOLSET FLAGS
# =====================================================================

ALPHARAVIS_LOAD_MCP_TOOLS=false
ALPHARAVIS_MCP_ALLOW_STDIO=false
ALPHARAVIS_ENABLE_STABLE_PROMPT_CONTEXT=true
ALPHARAVIS_ENABLE_TRUE_LAZY_TOOLSETS=true
ALPHARAVIS_SHOW_TOOLSET_CONTEXT=true
ALPHARAVIS_TOOLSET_MANIFEST_INCLUDE_TOOLS=true
ALPHARAVIS_TOOLSET_MANIFEST_MAX_TOOLS=16


# =====================================================================
# OPTIONAL PGVECTOR SEMANTIC MEMORY
# =====================================================================

ALPHARAVIS_VECTOR_BACKEND=off
ALPHARAVIS_ENABLE_PGVECTOR_MEMORY=false
ALPHARAVIS_PGVECTOR_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@vectordb:5432/rag_api
ALPHARAVIS_PGVECTOR_TABLE=alpharavis_memory_vectors
ALPHARAVIS_PGVECTOR_QUEUE_TABLE=alpharavis_embedding_jobs
ALPHARAVIS_PGVECTOR_CREATE_HNSW_INDEX=true
ALPHARAVIS_PGVECTOR_CATALOG_ENABLED=true
ALPHARAVIS_PGVECTOR_CHUNK_MAX_CHARS=6000
ALPHARAVIS_PGVECTOR_CHUNK_OVERLAP_CHARS=800
ALPHARAVIS_PGVECTOR_PREVIEW_CHARS=900
ALPHARAVIS_PGVECTOR_EMBEDDING_BASE_URL=http://litellm:4000/v1
ALPHARAVIS_PGVECTOR_EMBEDDING_API_KEY=
ALPHARAVIS_PGVECTOR_EMBEDDING_MODEL=memory-embed
ALPHARAVIS_PGVECTOR_FALLBACK_EMBEDDING_MODEL=memory-embed-fallback
ALPHARAVIS_PGVECTOR_EMBEDDING_TIMEOUT_SECONDS=20

ALPHARAVIS_EMBEDDING_JOB_BATCH_SIZE=10
ALPHARAVIS_EMBEDDING_KEEP_ALIVE=30m
ALPHARAVIS_OLLAMA_CHAT_KEEP_ALIVE=30m
ALPHARAVIS_EMBEDDING_SKIP_IF_CHAT_MODEL_LOADED=true
ALPHARAVIS_EMBEDDING_UNLOAD_CHAT_MODEL=false
ALPHARAVIS_EMBEDDING_RESTORE_CHAT_MODEL=true


# =====================================================================
# OPTIONAL VISION / MEDIA VECTOR MEMORY
# =====================================================================

ALPHARAVIS_ENABLE_VISION_VECTOR_MEMORY=false
ALPHARAVIS_VISION_PGVECTOR_TABLE=alpharavis_media_vectors
ALPHARAVIS_VISION_PGVECTOR_CREATE_HNSW_INDEX=true
ALPHARAVIS_VISION_EMBEDDING_BASE_URL=http://litellm:4000/v1
ALPHARAVIS_VISION_EMBEDDING_API_KEY=
ALPHARAVIS_VISION_EMBEDDING_MODEL=vision-embed
ALPHARAVIS_VISION_EMBEDDING_FALLBACK_MODEL=
ALPHARAVIS_VISION_EMBEDDING_TIMEOUT_SECONDS=30
ALPHARAVIS_VISION_EMBEDDING_FALLBACK_TEXT=true


# =====================================================================
# OPTIONAL MEMORY KERNEL / CURATED MEMORY
# =====================================================================

ALPHARAVIS_ENABLE_MEMORY_KERNEL=true
ALPHARAVIS_MEMORY_NUDGE_INTERVAL=10
ALPHARAVIS_MEMORY_KERNEL_PRECOMPRESS_NOTES=true
ALPHARAVIS_ALWAYS_MEMORY_MAX_ITEMS=6
ALPHARAVIS_ALWAYS_MEMORY_MAX_CHARS=2200
ALPHARAVIS_CURATED_MEMORY_ENTRY_MAX_CHARS=1200


# =====================================================================
# OPTIONAL SKILL LIBRARY / REPO AI SKILLS
# =====================================================================

ALPHARAVIS_ALLOW_SKILL_PROMOTION=false
ALPHARAVIS_ALLOW_SKILL_DRAFT_EXPORT=false
ALPHARAVIS_REPO_SKILLS_DIR=/workspace/ai-skills
ALPHARAVIS_REPO_SKILLS_CACHE_PATH=/workspace/.cache/alpharavis/repo_skill_manifest.json
ALPHARAVIS_REPO_SKILL_SUPPORTING_FILE_LIMIT=40
ALPHARAVIS_REPO_SKILL_HINT_LIMIT=3
ALPHARAVIS_REPO_SKILL_HINT_MAX_CHARS=3000
ALPHARAVIS_REPO_SKILL_INCLUDE_DRAFTS=false


# =====================================================================
# OPTIONAL ARTIFACTS / FILE SAFETY
# =====================================================================

ALPHARAVIS_ARTIFACT_ROOT=/workspace/artifacts/alpharavis
ALPHARAVIS_WRITE_SAFE_ROOT=
ALPHARAVIS_ARCHITECTURE_DOC_PATH=/workspace/docs/ALPHARAVIS_ARCHITECTURE.md


# =====================================================================
# OPTIONAL HANDOFF / DEBUGGER SAFETY
# =====================================================================

ALPHARAVIS_ENABLE_HANDOFF_CONTEXT_GUARD=true
ALPHARAVIS_HANDOFF_CONTEXT_TOKEN_LIMIT=12000
ALPHARAVIS_HANDOFF_PACKET_MAX_CHARS=4000
ALPHARAVIS_DEBUGGER_COMMAND_TIMEOUT_SECONDS=45
ALPHARAVIS_LOCAL_COMMAND_TIMEOUT_SECONDS=45
ALPHARAVIS_LOCAL_COMMAND_MAX_OUTPUT_CHARS=12000


# =====================================================================
# OPTIONAL ERROR CLASSIFICATION
# =====================================================================

ALPHARAVIS_ENABLE_ERROR_CLASSIFIER=true
BRIDGE_SHOW_ERROR_CLASSIFICATION=true
