# =====================================================================
# --- REMOTE PC CONFIGURATION ---
# =====================================================================
# Format: JSON object where each key is a PC name (used by the agent).
# Required fields per PC:
#   "ip"  — Local IP address of the PC
#   "mac" — MAC address for Wake-on-LAN (format: AA:BB:CC:DD:EE:FF)
#
# Optional fields per PC:
#   "ssh_pass" — SSH password for THIS specific PC.
#                If not set, SSH_PASS_DEFAULT is used as fallback.
#
# Add as many PCs as you want — the agent will know all of them automatically.
#
# Example with 2 PCs (one uses default password, one has its own):
# REMOTE_PCS='{"main_pc": {"ip": "192.168.178.140", "mac": "AA:BB:CC:DD:EE:FF"}, "comfy_server": {"ip": "192.168.178.50", "mac": "11:22:33:44:55:66", "ssh_pass": "myOtherPassword"}}'
#
REMOTE_PCS='{"main_pc": {"ip": "192.168.178.140", "mac": "AA:BB:CC:DD:EE:FF"}, "comfy_server": {"ip": "192.168.178.50", "mac": "11:22:33:44:55:66"}}'


# =====================================================================
# --- SSH CREDENTIALS ---
# =====================================================================

# SSH_USER: The Linux username used for all SSH connections.
# Default: root
SSH_USER=root

# SSH_PASS_DEFAULT: The default SSH password used for ALL PCs
# unless a PC has its own "ssh_pass" set in REMOTE_PCS above.
#
# To use SSH key auth instead (more secure):
#   1. Leave SSH_PASS_DEFAULT empty
#   2. Mount your SSH keys into the container in docker-compose.yml:
#      volumes:
#        - ~/.ssh:/root/.ssh:ro
#
SSH_PASS_DEFAULT=yourPasswordHere


# =====================================================================
# --- REDIS ---
# =====================================================================
# Used for LLM response caching (speeds up repeated questions).
# Default points to the Redis container in docker-compose.yml.
# Only change if you use an external Redis instance.
