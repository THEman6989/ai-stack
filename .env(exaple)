# =====================================================================
# OPTIONAL BRIDGE SETTINGS - LIBRECHAT <-> LANGGRAPH
# =====================================================================

# Max seconds the bridge waits for one LangGraph run before returning a clean
# timeout message to LibreChat.
BRIDGE_RUN_TIMEOUT_SECONDS=180

# Streaming mode for LibreChat.
# Allowed values:
#   events          = stream LangGraph message events as OpenAI SSE chunks
#   final, messages = wait for final content and stream one OpenAI SSE reply
BRIDGE_STREAM_MODE=events

# How the bridge syncs LibreChat messages into LangGraph.
# Allowed values:
#   delta = after the first thread sync, send only new user messages
#   full  = send the whole LibreChat message array every request
#
# Recommended: delta. It keeps LangGraph compression useful because LibreChat's
# full visible UI history is not re-injected on every turn.
BRIDGE_MESSAGE_SYNC_MODE=delta

# If true, the bridge emits short visible "Status:" chunks during streaming.
# Allowed values: true, false
BRIDGE_SHOW_ACTIVITY_EVENTS=false

# Activity detail level when BRIDGE_SHOW_ACTIVITY_EVENTS=true.
# Allowed values:
#   summary = show short LangGraph step summaries
#   debug   = also show raw non-message event names
#   off     = suppress activity chunks even if the boolean is true
BRIDGE_ACTIVITY_DETAIL=summary

# If true, reasoning/thinking deltas from LangGraph/LLM events are forwarded as
# a separate OpenAI-style delta field instead of normal visible content.
# LibreChat support depends on the frontend/provider parser. Keep false if the
# UI shows reasoning as normal text.
# Allowed values: true, false
BRIDGE_STREAM_REASONING_EVENTS=false

# Delta field name used when BRIDGE_STREAM_REASONING_EVENTS=true.
# Common values:
#   reasoning_content = many OpenAI-compatible local servers / LiteLLM style
#   reasoning         = some experimental clients
BRIDGE_REASONING_DELTA_FIELD=reasoning_content

# Adds POST /v1/responses as a compatibility wrapper around the same LangGraph
# run path used by /v1/chat/completions. Chat Completions remains the primary
# LibreChat path.
# Allowed values: true, false
BRIDGE_ENABLE_RESPONSES_API=true

# Preferred external API mode for clients that can choose. Chat Completions stays
# enabled for LibreChat compatibility; Responses has richer output item events.
# Allowed values: responses, chat_completions
BRIDGE_PREFERRED_API_MODE=responses

# Bridge-level hard cutoff before the request is sent to LangGraph. Set 0 to
# disable. If BRIDGE_HARD_INPUT_HTTP_ERROR=false, the bridge returns a visible
# assistant message instead of an HTTP 413.
BRIDGE_HARD_INPUT_TOKEN_LIMIT=128000
BRIDGE_HARD_INPUT_HTTP_ERROR=false

# Bridge-side real generation smoke test.
# Endpoint: GET /health/llm-generation on api-bridge.
# It checks actual token generation through LiteLLM, not only process health.
BRIDGE_LLM_HEALTH_URL=http://litellm:4000/v1
BRIDGE_LLM_HEALTH_API_KEY=sk-local-dev
BRIDGE_LLM_HEALTH_MODEL=big-boss
BRIDGE_LLM_HEALTH_FALLBACK_MODEL=edge-gemma
BRIDGE_LLM_HEALTH_TIMEOUT_SECONDS=10
BRIDGE_LLM_HEALTH_PROMPT=Antworte nur mit OK.

# Optional Hermes -> LangGraph tool endpoint exposed by api-bridge.
# Endpoint: POST /tools/langgraph/run
# It is disabled by default and also requires explicit_user_request=true in the
# JSON body, so Hermes cannot silently loop into LangGraph.
# Allowed values: true, false
BRIDGE_ENABLE_LANGGRAPH_TOOL=false

# Optional bearer token for POST /tools/langgraph/run.
# If set, clients must send Authorization: Bearer <this value>.
BRIDGE_LANGGRAPH_TOOL_API_KEY=sk-langgraph-tool-local

# Max seconds a Hermes-triggered LangGraph tool run may wait.
BRIDGE_LANGGRAPH_TOOL_TIMEOUT_SECONDS=120

# Optional generic LibreChat "OpenAI" provider.
# Leave both empty to avoid a duplicate OpenAI bucket in the model picker.
# The named "LangGraph Agent" and "Hermes Agent" custom endpoints still work.
# To intentionally expose the bridge as LibreChat's generic OpenAI endpoint:
#   LIBRECHAT_OPENAI_API_KEY=sk-1234
#   LIBRECHAT_OPENAI_REVERSE_PROXY=http://api-bridge:8123/v1
LIBRECHAT_OPENAI_API_KEY=
LIBRECHAT_OPENAI_REVERSE_PROXY=


# =====================================================================
# OPTIONAL MEMORY + CONTEXT COMPRESSION
# =====================================================================

# Approximate active message-window token limit. If the current LangGraph
# thread goes above this, older messages are summarized and archived.
ALPHARAVIS_ACTIVE_TOKEN_LIMIT=10000

# Number of most recent messages kept verbatim after chat compression.
ALPHARAVIS_CONTEXT_KEEP_LAST_MESSAGES=12

# Enables second-tier compression for old archive blocks.
# Allowed values: true, false
ALPHARAVIS_ENABLE_HIERARCHICAL_COMPRESSION=true

# If true, automatic compression only happens after the current graph run has
# produced an answer. This avoids compressing in the middle of a task.
# Allowed values: true, false
ALPHARAVIS_ENABLE_POST_RUN_COMPRESSION=true

# Approximate token budget for uncompressed archive records inside one chat.
# Above this, older archive records are summarized into an archive collection.
ALPHARAVIS_ARCHIVE_TOKEN_LIMIT=50000

# Number of newest archive records kept separate during archive collection
# compression.
ALPHARAVIS_ARCHIVE_KEEP_RECENT_RECORDS=8

# Allows the user to pause compression for one run by saying things like:
#   keine Kompression
#   nicht komprimieren
#   skip compression
# Allowed values: true, false
ALPHARAVIS_ALLOW_USER_COMPRESSION_PAUSE=true

# Optional pipe-separated phrases that force manual compression for one run.
# Leave empty to use built-in German/English phrases such as:
#   komprimiere jetzt
#   archiviere jetzt
#   compress now
ALPHARAVIS_MANUAL_COMPRESSION_PATTERNS=

# If true, AlphaRavis adds a visible Memory-Notice to LibreChat whenever
# compression happens or when compression was explicitly paused.
ALPHARAVIS_SHOW_MEMORY_NOTICES=true

# Max archive-search hits returned inside the current chat thread.
# This keeps retrieval bounded instead of dumping history.
ALPHARAVIS_ARCHIVE_SEARCH_LIMIT=5

# Max archive-search hits when the user explicitly asks to search other chats
# through include_other_threads=true.
ALPHARAVIS_CROSS_THREAD_ARCHIVE_SEARCH_LIMIT=3

# Enables the Hermes-inspired AlphaRavis MemoryKernel.
# The kernel only runs on the normal agent path, not on Fast Path.
# It prefetches small curated memories, adds memory nudges, indexes finished
# turns for later search, and feeds durable hints into compression.
# Allowed values: true, false
ALPHARAVIS_ENABLE_MEMORY_KERNEL=true

# Number of user turns between invisible memory nudges to the agents.
# Set 0 to disable nudges.
ALPHARAVIS_MEMORY_NUDGE_INTERVAL=10

# If true, possible durable facts from old messages are passed into the
# compression prompt so summaries preserve memory-worthy details.
# Allowed values: true, false
ALPHARAVIS_MEMORY_KERNEL_PRECOMPRESS_NOTES=true

# Curated memory is the small always-retrievable layer inspired by Hermes
# MEMORY.md/USER.md. It is separate from raw chat archives and from LangMem.
ALPHARAVIS_ALWAYS_MEMORY_MAX_ITEMS=6
ALPHARAVIS_ALWAYS_MEMORY_MAX_CHARS=2200
ALPHARAVIS_CURATED_MEMORY_ENTRY_MAX_CHARS=1200
ALPHARAVIS_CURATED_MEMORY_SEARCH_LIMIT=5

# Indexed session-history search, inspired by Hermes SQLite/FTS5 session search.
# Current-thread search is default; cross-thread search only happens when a tool
# call explicitly sets include_other_threads=true.
ALPHARAVIS_SESSION_SEARCH_LIMIT=5
ALPHARAVIS_CROSS_THREAD_SESSION_SEARCH_LIMIT=3

# Disk-backed artifacts for long reports, logs, plans, or intermediate notes.
# Agents should write large material here and keep only a short summary in chat.
# Inside Docker, /workspace/artifacts/alpharavis is the default.
ALPHARAVIS_ENABLE_ARTIFACTS=true
ALPHARAVIS_ARTIFACT_ROOT=/workspace/artifacts/alpharavis
ALPHARAVIS_ARTIFACT_MAX_CHARS=120000
ALPHARAVIS_ARTIFACT_INDEX_PREVIEW_CHARS=4000
ALPHARAVIS_ARTIFACT_READ_MAX_CHARS=24000
ALPHARAVIS_ARTIFACT_LIST_LIMIT=10

# Editable on-demand self-description. Agents do not inject this into every
# chat; they read it only when asked about AlphaRavis itself.
ALPHARAVIS_ARCHITECTURE_DOC_PATH=/workspace/docs/ALPHARAVIS_ARCHITECTURE.md

# Max characters returned by the architecture-doc tool in one call.
ALPHARAVIS_ARCHITECTURE_DOC_MAX_CHARS=6000


# =====================================================================
# OPTIONAL VECTOR MEMORY - PGVECTOR SEMANTIC SEARCH SIDECAR
# =====================================================================

# Vector backend switch.
# Allowed values:
#   off      = no semantic vector indexing/search
#   pgvector = use the existing Postgres/pgvector container as a search index
#
# MongoDB remains the source of truth for LangGraph checkpoints/store. pgvector
# stores complete retrieval chunks plus a source catalog/Inhaltsverzeichnis
# built from the original source data. source_key points back to Mongo/store,
# artifact files, or the federated RAG document source.
ALPHARAVIS_VECTOR_BACKEND=pgvector

# Legacy boolean alias for enabling pgvector memory.
# Allowed values: true, false
ALPHARAVIS_ENABLE_PGVECTOR_MEMORY=true

# Postgres/pgvector connection used by LangGraph. Docker default points to the
# existing `vectordb` service.
ALPHARAVIS_PGVECTOR_DATABASE_URL=postgresql://postgres:f3423f423f423f423f423f423f423f42@vectordb:5432/rag_api

# Table name for AlphaRavis vector index records.
ALPHARAVIS_PGVECTOR_TABLE=alpharavis_memory_vectors

# OpenAI-compatible embedding endpoint used to create vectors.
# Inside Docker, LiteLLM exposes the `memory-embed` route at this URL.
ALPHARAVIS_PGVECTOR_EMBEDDING_BASE_URL=http://litellm:4000/v1
ALPHARAVIS_PGVECTOR_EMBEDDING_API_KEY=sk-local-dev
ALPHARAVIS_PGVECTOR_EMBEDDING_MODEL=memory-embed
ALPHARAVIS_PGVECTOR_FALLBACK_EMBEDDING_MODEL=memory-embed-fallback
ALPHARAVIS_PGVECTOR_EMBEDDING_TIMEOUT_SECONDS=20

# Indexing mode.
# Allowed values:
#   background = schedule pgvector indexing after Mongo/store write succeeds
#   inline     = await pgvector indexing; useful for tests
ALPHARAVIS_PGVECTOR_INDEX_MODE=background

# Store full retrieval chunks in pgvector, not only tiny previews.
# Allowed values: true, false
ALPHARAVIS_PGVECTOR_STORE_FULL_CHUNKS=true

# Store one extra catalog/Inhaltsverzeichnis row per source. It is extracted
# from the complete original data and lists source type, source key, metadata,
# headings, code symbols, file paths, database/RAG topics, and chunk map.
# Allowed values: true, false
ALPHARAVIS_PGVECTOR_CATALOG_ENABLED=true

# Chunking controls for full source text. Long chats, archives, code, and
# artifacts are split into overlapping chunks; each chunk gets its own vector.
ALPHARAVIS_PGVECTOR_CHUNK_MAX_CHARS=6000
ALPHARAVIS_PGVECTOR_CHUNK_OVERLAP_CHARS=800
ALPHARAVIS_PGVECTOR_PREVIEW_CHARS=900

# Number of completed chat turns used for one session-turn vector window.
# 2 means Turn 1+2, then Turn 2+3, which preserves pronoun/context links.
ALPHARAVIS_PGVECTOR_SESSION_WINDOW_TURNS=2

# Create a pgvector HNSW index automatically. If creation fails, exact vector
# search still works but may be slower on large memory collections.
# Allowed values: true, false
ALPHARAVIS_PGVECTOR_CREATE_HNSW_INDEX=true

# Search limits for semantic_memory_search.
ALPHARAVIS_PGVECTOR_SEARCH_LIMIT=5
ALPHARAVIS_CROSS_THREAD_VECTOR_SEARCH_LIMIT=3
ALPHARAVIS_PGVECTOR_RESULT_PREVIEW_CHARS=900

# Automatic MemoryKernel semantic prefetch. This only runs when vector backend
# is enabled; it never searches other threads unless a tool call explicitly does.
# Allowed values: true, false
ALPHARAVIS_PGVECTOR_PREFETCH_ENABLED=true
ALPHARAVIS_PGVECTOR_PREFETCH_LIMIT=3
ALPHARAVIS_PGVECTOR_PREFETCH_MAX_CHARS=1800

# Federated document RAG search. When semantic_memory_search runs, AlphaRavis
# also queries the existing rag_api pgvector index and normalizes those hits as
# external_document results instead of duplicating the document DB.
# Allowed values: true, false
ALPHARAVIS_ENABLE_RAG_FEDERATED_SEARCH=true
ALPHARAVIS_RAG_API_URL=http://rag_api:8000
ALPHARAVIS_RAG_FEDERATED_TIMEOUT_SECONDS=20
ALPHARAVIS_RAG_FEDERATED_MAX_FILE_IDS=200
ALPHARAVIS_RAG_RESULT_PREVIEW_CHARS=1400


# =====================================================================
# OPTIONAL SAFE WORKFLOW SKILL LIBRARY
# =====================================================================

# Enables retrieval/storage of reusable workflow skills in MongoDBStore.
# Active skills are non-binding hints only; they do not execute tools directly.
# Allowed values: true, false
ALPHARAVIS_ENABLE_SKILL_LIBRARY=true

# Max number of approved active skills retrieved for the current user task.
ALPHARAVIS_SKILL_LIBRARY_SEARCH_LIMIT=3

# Max characters from retrieved active skills injected into the graph prompt.
ALPHARAVIS_SKILL_CONTEXT_MAX_CHARS=2500

# Max reviewed repo skill-card metadata hints injected before the agent path.
# These are short names/descriptions only; the full SKILL.md is loaded only when
# the agent calls read_repo_ai_skill.
ALPHARAVIS_REPO_SKILL_HINT_LIMIT=3

# Safety switch for promoting an inactive skill candidate into an active skill.
# Keep false by default. Temporarily set true only while intentionally reviewing
# and promoting a specific candidate.
# Allowed values: true, false
ALPHARAVIS_ALLOW_SKILL_PROMOTION=false


# =====================================================================
# OPTIONAL SEARCH / RESEARCH
# =====================================================================

# Required only for the deep_web_research tool.
# Get a key at: https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =====================================================================
# OPTIONAL OBSERVABILITY
# =====================================================================

# LangSmith API key for LangGraph/LangChain tracing.
# Optional for local development. If missing or invalid, the stack still runs,
# but logs may show 403 warnings from LangSmith metadata/run submission.
LANGCHAIN_API_KEY=dein_langsmith_key_hier


# =====================================================================
# OPTIONAL LITELLM / LLM / CACHE / SAFETY
# =====================================================================

# Enables the direct fast-chat route for short non-tool questions. This skips
# skill retrieval and the swarm, but still runs through LangGraph state.
# Allowed values: true, false
ALPHARAVIS_ENABLE_FAST_PATH=true

# Max latest-user-message length eligible for fast path.
ALPHARAVIS_FAST_PATH_MAX_CHARS=360

# Fast-path timeout for the primary big-boss model.
ALPHARAVIS_FAST_PATH_PRIMARY_TIMEOUT_SECONDS=20

# Allows only the fast path to fall back to edge-gemma if big-boss is stuck.
# Complex tool/agent workflows do not use this fallback.
# Allowed values: true, false
ALPHARAVIS_FAST_PATH_ENABLE_FALLBACK=true

# LiteLLM model id for the small starter/crisis fallback.
ALPHARAVIS_FAST_PATH_FALLBACK_MODEL=openai/edge-gemma

# Timeout for the small fallback model in fast path.
ALPHARAVIS_FAST_PATH_FALLBACK_TIMEOUT_SECONDS=45

# Output cap and temperature for fast-path direct answers.
ALPHARAVIS_FAST_PATH_MAX_TOKENS=256
ALPHARAVIS_FAST_PATH_TEMPERATURE=0

# Passes llama.cpp/Qwen chat template kwargs to disable hidden thinking only in
# fast path. This is what makes simple "OK" style replies actually fast.
# Set false if you want hidden thinking even when Fast Path is active.
# Allowed values: true, false
ALPHARAVIS_FAST_PATH_DISABLE_THINKING=true

# If true, fast-path replies visibly say that Fast Path was used.
# Allowed values: true, false
ALPHARAVIS_SHOW_FAST_PATH_NOTICE=true

# If true, once a thread uses the normal swarm/agent path, future turns in that
# same thread cannot return to Fast Path. This prevents mixed simple/complex
# state from bouncing between execution modes.
# Allowed values: true, false
ALPHARAVIS_FAST_PATH_LOCK_AFTER_SWARM=true

# Normal agent path thinking controls for llama.cpp/Qwen-style models.
# These are sent through chat_template_kwargs where the backend supports them.
# Fast Path can still disable thinking separately with the setting above.
# Allowed values: true, false
ALPHARAVIS_ENABLE_THINKING=true
ALPHARAVIS_PRESERVE_THINKING=true

# Lightweight router-planner. It runs only on complex agent-path tasks and
# injects a short execution plan before the swarm starts.
# Allowed values: true, false
ALPHARAVIS_ENABLE_PLANNER_NODE=true
ALPHARAVIS_PLANNER_MIN_QUERY_CHARS=500
ALPHARAVIS_PLANNER_MAX_CHARS=1800
ALPHARAVIS_PLANNER_TIMEOUT_SECONDS=45
ALPHARAVIS_TASK_BRIEF_MAX_CHARS=2000

# Agent handoff safety. Before the swarm starts, AlphaRavis can shrink an
# oversized active context into a handoff summary while preserving the current
# task brief, skill/memory hints, latest handoff packet, and recent messages.
# Agents are instructed to create build_specialist_report handoff packets before
# transfer_to_* calls.
# Allowed values: true, false
ALPHARAVIS_ENABLE_HANDOFF_CONTEXT_GUARD=true
ALPHARAVIS_HANDOFF_CONTEXT_TOKEN_LIMIT=8500
ALPHARAVIS_HANDOFF_CONTEXT_KEEP_LAST_MESSAGES=16
ALPHARAVIS_HANDOFF_PACKET_MAX_CHARS=4000
ALPHARAVIS_HANDOFF_SUMMARY_MAX_CHARS=2600
ALPHARAVIS_HANDOFF_SUMMARY_TIMEOUT_SECONDS=45

# If true, appends a visible Run-Profile message after replies. Normally keep
# false and inspect run_profile in LangGraph Studio/DeepAgents UI instead.
# Allowed values: true, false
ALPHARAVIS_SHOW_RUN_PROFILE=false

# Loads optional MCP tools during graph construction.
# Default false because MCP loading can add seconds to every request. The native
# Pixelle HTTP tool still works without this.
# Allowed values: true, false
ALPHARAVIS_LOAD_MCP_TOOLS=false

# Primary DeepAgents-style MCP config file.
# Default in Docker:
#   /workspace/langgraph-app/mcp.json
# The default config exposes Pixelle MCP through SSE when MCP loading is enabled.
ALPHARAVIS_MCP_CONFIG_PATH=/workspace/langgraph-app/mcp.json

# Optional extra MCP config files, pipe-separated. Later files override earlier
# server names. Example:
#   /workspace/.mcp.json|/workspace/private-mcp.json
ALPHARAVIS_MCP_CONFIG_PATHS=

# Allows stdio MCP servers from config files. Keep false unless the config is
# trusted, because stdio MCP can start local processes.
# Allowed values: true, false
ALPHARAVIS_MCP_ALLOW_STDIO=false

# Prefix MCP tool names with the server name when the adapter supports it.
# This avoids collisions when several MCP servers expose similar tool names.
# Allowed values: true, false
ALPHARAVIS_MCP_TOOL_PREFIX=true

# If true, a broken MCP config/server fails graph startup. If false, AlphaRavis
# logs the MCP warning and continues without those optional tools.
# Allowed values: true, false
ALPHARAVIS_MCP_STRICT=false

# Enables Redis-backed LLM cache for repeated identical LLM calls.
# Recommended during development: false, so responses do not feel stale.
# Allowed values: true, false
ALPHARAVIS_ENABLE_REDIS_CACHE=false

# Timeout in seconds for individual LLM requests made by AlphaRavis.
ALPHARAVIS_LLM_TIMEOUT_SECONDS=120

# Number of model-call retries inside ChatLiteLLM.
# Recommended during development: 0, so failures stay visible.
ALPHARAVIS_LLM_MAX_RETRIES=0

# Enables streaming mode on the LLM client so LangGraph can expose token/message
# events when the upstream model/provider supports them.
# Allowed values: true, false
ALPHARAVIS_LLM_STREAMING=true

# If true, SSH/local debugger commands that look destructive or state-changing
# trigger a LangGraph human approval interrupt before execution.
# Allowed values: true, false
ALPHARAVIS_REQUIRE_COMMAND_APPROVAL=true

# Max seconds allowed for local diagnostic shell commands in the LangGraph
# container, such as read-only docker logs/ps checks.
ALPHARAVIS_LOCAL_COMMAND_TIMEOUT_SECONDS=45

# Optional cloud model keys, only needed if you add cloud fallback models.
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
