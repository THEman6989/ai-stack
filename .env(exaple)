# =====================================================================
# OPTIONAL BRIDGE SETTINGS - LIBRECHAT <-> LANGGRAPH
# =====================================================================

# Max seconds the bridge waits for one LangGraph run before returning a clean
# timeout message to LibreChat.
BRIDGE_RUN_TIMEOUT_SECONDS=180

# Streaming mode for LibreChat.
# Allowed values:
#   events          = stream LangGraph message events as OpenAI SSE chunks
#   final, messages = wait for final content and stream one OpenAI SSE reply
BRIDGE_STREAM_MODE=events

# How the bridge syncs LibreChat messages into LangGraph.
# Allowed values:
#   delta = after the first thread sync, send only new user messages
#   full  = send the whole LibreChat message array every request
#
# Recommended: delta. It keeps LangGraph compression useful because LibreChat's
# full visible UI history is not re-injected on every turn.
BRIDGE_MESSAGE_SYNC_MODE=delta

# If true, the bridge emits short visible "Status:" chunks during streaming.
# Allowed values: true, false
BRIDGE_SHOW_ACTIVITY_EVENTS=false

# Activity detail level when BRIDGE_SHOW_ACTIVITY_EVENTS=true.
# Allowed values:
#   summary = show short LangGraph step summaries
#   debug   = also show raw non-message event names
#   off     = suppress activity chunks even if the boolean is true
BRIDGE_ACTIVITY_DETAIL=summary

# If true, reasoning/thinking deltas from LangGraph/LLM events are forwarded as
# a separate OpenAI-style delta field instead of normal visible content.
# LibreChat support depends on the frontend/provider parser. Keep false if the
# UI shows reasoning as normal text.
# Allowed values: true, false
BRIDGE_STREAM_REASONING_EVENTS=false

# Delta field name used when BRIDGE_STREAM_REASONING_EVENTS=true.
# Common values:
#   reasoning_content = many OpenAI-compatible local servers / LiteLLM style
#   reasoning         = some experimental clients
BRIDGE_REASONING_DELTA_FIELD=reasoning_content

# Adds POST /v1/responses over the same LangGraph run path used by
# /v1/chat/completions. The bridge also exposes bridge-local compatibility
# routes for GET/DELETE /v1/responses/{id}, GET /v1/responses/{id}/input_items,
# POST /v1/responses/{id}/cancel, POST /v1/responses/input_tokens, and explicit
# 501 for /v1/responses/compact.
# Streaming uses Responses-style semantic SSE events.
# Allowed values: true, false
BRIDGE_ENABLE_RESPONSES_API=true

# Preferred external API mode for clients that can choose. Chat Completions stays
# enabled for LibreChat compatibility; Responses has richer output item events.
# Allowed values: responses, chat_completions
BRIDGE_PREFERRED_API_MODE=responses

# In-process retrieval support for GET/DELETE /v1/responses/{response_id}.
# This is a bridge-local compatibility cache, not long-term memory.
# Allowed values: true, false
BRIDGE_RESPONSES_STORE=true
BRIDGE_RESPONSES_STORE_MAX=200

# Keep a final data: [DONE] sentinel after Responses SSE streams for broad client
# compatibility. The semantic events still carry the real Responses lifecycle.
# Allowed values: true, false
BRIDGE_RESPONSES_DONE_SENTINEL=true

# Client-supplied OpenAI-hosted Responses tools (web_search/file_search/code
# interpreter/computer/shell/etc.) are not executed by the bridge. Keep this
# false so clients receive an explicit error instead of a fake tool run.
# AlphaRavis internal LangGraph tools remain available inside the graph.
# Allowed values: true, false
BRIDGE_RESPONSES_ALLOW_CLIENT_TOOLS=false

# Raw media safety for LibreChat/OpenWebUI inputs.
# Allowed BRIDGE_MEDIA_CONTEXT_MODE values:
#   metadata = replace media blocks with file_id/url/type metadata markers
#   off      = drop media blocks unless text is present
# BRIDGE_ALLOW_RAW_MEDIA_CONTEXT=true passes raw multimodal blocks through; keep
# false until the target LangGraph/model path is explicitly vision-capable.
BRIDGE_ALLOW_RAW_MEDIA_CONTEXT=false
BRIDGE_MEDIA_CONTEXT_MODE=metadata

# Bridge-side internal context hygiene.
# BRIDGE_SCRUB_INTERNAL_CONTEXT=true strips internal blocks such as
# <memory-context>...</memory-context> from visible LibreChat/OpenAI output,
# including streamed chunks where the tag can be split across deltas.
# Allowed values: true, false
BRIDGE_SCRUB_INTERNAL_CONTEXT=true

# Explicit @ context references in user messages.
# When enabled, the bridge can expand bounded references before LangGraph sees
# the message:
#   @file:path/to/file.py:10-40
#   @folder:path/to/folder
#   @diff
#   @staged
#   @git:3
#   @url:https://example.com/page
#
# Files are resolved inside BRIDGE_CONTEXT_REFERENCE_WORKSPACE_ROOT. Sensitive
# config/credential paths such as .env, .ssh, .aws, .kube, .docker are refused.
# URL fetching is explicit-user-message only and can be disabled separately.
BRIDGE_ENABLE_CONTEXT_REFERENCES=true
BRIDGE_CONTEXT_REFERENCES_FETCH_URLS=true
BRIDGE_CONTEXT_REFERENCE_WORKSPACE_ROOT=
BRIDGE_CONTEXT_REFERENCE_CWD=
BRIDGE_CONTEXT_REFERENCE_CONTEXT_LENGTH=128000
BRIDGE_CONTEXT_REFERENCE_SOFT_RATIO=0.25
BRIDGE_CONTEXT_REFERENCE_HARD_RATIO=0.50
BRIDGE_CONTEXT_REFERENCE_MAX_URL_CHARS=12000
BRIDGE_CONTEXT_REFERENCE_MAX_FILE_CHARS=20000
